# Warehouse Management System - Backend Environment Variables
# Copy this file to .env and fill in your actual values for production

# Server Configuration
PORT=8080

# Database Configuration (Render PostgreSQL)
DB_URL=jdbc:postgres
DB_USERNAME=c
DB_PASSWORD=]

# JWT Configuration (IMPORTANT: Change this to a secure random string in production)
JWT_SECRET=warehouse-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256-encryption-algo

# Logging
LOG_LEVEL=INFO
